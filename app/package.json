{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "tsc -b && vite build && electron-builder -l",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cronstrue": "^3.14.0",
    "crypto-js": "^4.2.0",
    "diff": "^9.0.0",
    "lucide-react": "^0.577.0",
    "node-forge": "^1.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/crypto-js": "^4.2.2",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.12.0",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
